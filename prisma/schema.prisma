// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Template {
  id        String   @id @default(uuid())
  channel   String
  name      String
  subject   String?
  htmlBody  String?
  textBody  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channel])
  @@index([name])
}

model DeliveryLog {
  id          String   @id @default(uuid())
  jobId       String
  userId      String
  channel     String
  status      String   // "DELIVERED" | "FAILED" | "SKIPPED" | "RATE_LIMITED"
  providerRef String?
  error       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([jobId])
  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}
