NODE_ENV=development
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notifications

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=no-reply@yourdomain.com

# Meta / WhatsApp
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=

# Worker
WORKER_CONCURRENCY=5

# Rate limits (per hour)
RATE_LIMIT_EMAIL=10
RATE_LIMIT_SMS=3
RATE_LIMIT_PUSH=20
RATE_LIMIT_WHATSAPP=5
RATE_LIMIT_IN_APP=100
